# 使用官方 LTS 版本
FROM jenkins/jenkins:lts

# 切換到 root 以安裝系統套件
USER root

# 安裝 Python 3 與 pip
RUN apt-get update && \
    apt-get install -y python3 python3-pip python3-venv && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# 預先安裝你的 AI Agent 需要的套件
# 這裡使用 --break-system-packages 是因為 Debian 12+ 的安全限制
RUN pip3 install --no-cache-dir google-generativeai --break-system-packages

# 切換回 jenkins 使用者以保持安全
USER jenkins